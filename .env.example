# PostgreSQL Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=resume_platform
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:your_postgres_password_here@localhost:5432/resume_platform

# ChromaDB Vector Database Configuration
CHROMA_HOST=localhost
CHROMA_PORT=8000

# FastAPI Backend Configuration
API_V1_STR=/api/v1
PROJECT_NAME="AI Resume Intelligence Platform"
SECRET_KEY=generate_a_secure_random_key_for_production_here
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# Frontend Configuration
VITE_API_URL=http://localhost:8080/api/v1

# Gemini API Key Configuration
GEMINI_API_KEY=your_gemini_api_key_here

